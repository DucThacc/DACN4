# Web-WAF Environment Configuration
# ===================================

# MySQL/DVWA
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=dvwa
MYSQL_USER=dvwa
MYSQL_PASSWORD=dvwa
MYSQL_HOSTNAME=mysql

# DVWA PHP Config
PHP_MEMORY_LIMIT=128M
PHP_MAX_EXECUTION_TIME=300

# ModSecurity
# Values: DetectionOnly (default) | On (blocking mode)
MODSECURITY_ENGINE=DetectionOnly

# ⚠️ IP CONFIGURATION FOR UBUNTU SERVER
# Thay đổi các IP này khi deploy trên Ubuntu Server:
# - DVWA_HOST: IP của Ubuntu Server (VD: 192.168.1.100)
# - MYSQL_HOST: localhost (nếu chạy trong Docker network)
DVWA_HOST=localhost
MYSQL_HOST=mysql
